# ─── Required ───────────────────────────────────────────────
# Anthropic API key — powers post generation, voice analysis, daily ideas.
ANTHROPIC_API_KEY=sk-ant-...

# ─── Admin dashboard (set both to enable /adminlogin) ────────
ADMIN_EMAIL=you@email.com
ADMIN_PASSWORD=choose-a-strong-password

# ─── Persistent storage (CRITICAL on Railway) ───────────────
# Railway's filesystem is WIPED on every deploy/restart. Attach a Railway Volume so
# user profiles, signups/leads and usage survive. When a Volume is attached Railway
# sets RAILWAY_VOLUME_MOUNT_PATH automatically and the app uses it — no value needed.
# Set DATA_DIR only to override that path (e.g. for local testing).
DATA_DIR=

# ─── Optional — lead capture to a Google Sheet ──────────────
# Apps Script web-app URL (see supabase-setup notes). Leave blank to store leads locally only.
GOOGLE_SHEET_WEBHOOK_URL=

# ─── Optional — extra news sources for the scraper ──────────
# The scraper works on RSS alone (500-1000 articles). These keys ADD more coverage.
# NewsAPI — free 100 requests/day: https://newsapi.org/register
NEWSAPI_KEY=
# The Guardian — completely free, unlimited: https://open-platform.theguardian.com/access/
GUARDIAN_API_KEY=
# Currents API — free 600 requests/day: https://currentsapi.services/en/register
CURRENTS_API_KEY=
